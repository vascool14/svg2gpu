{
	"compilerOptions": {
		"target": "es6",
		"module": "esnext",
		"declaration": true,
		"declarationMap": false,
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "node"
	},
	"include": ["src"]
}
