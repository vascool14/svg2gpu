	"disableSources": true,
	"navigationLinks": {
		"Examples": "https://www.svg2gpu.com/examples",
		"Docs": "https://www.svg2gpu.com/docs",
		"NPM": "https://www.npmjs.com/package/svg2gpu",
		"GitHub": "https://github.com/Vascool14/svg2gpu"
	}
}
