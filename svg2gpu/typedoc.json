{
	"entryPoints": ["src"],
	"out": "../client/public/typedoc",
	"name": "svg2GPU API Docs",
	"includeVersion": true,
	"readme": "README.md",
	"customCss": "../client/typedoc/typedoc.css",
	"titleLink": "https://www.svg2gpu.com",
	"categorizeByGroup": false,
	"sort": ["kind"],
	"theme": "default",

	"excludePrivate": true,
	"excludeExternals": true,
